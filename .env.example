# Neon Postgres connection string.
# Create a project at https://console.neon.tech/, copy the pooled connection string here.
# Without this set, the app runs entirely on mock data.
DATABASE_URL=

# X (Twitter) v2 API Bearer token (Basic tier or higher).
# Without this set, /api/cron/ingest is a no-op even when DATABASE_URL is set.
X_API_BEARER=

# Required by /api/cron/* so the open internet can't trigger ingestion.
# Vercel's cron pings include `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: when set, narrative classification upgrades from keyword v0 to
# embedding-based clustering via text-embedding-3-small.
OPENAI_API_KEY=

# Clerk auth. Get keys from https://dashboard.clerk.com/ → API Keys.
# Required to gate /app/* behind real sign-in. When unset, the middleware
# is a no-op and /sign-in shows a "Clerk not configured" notice — the
# marketing site and demo dashboard still render.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk redirect overrides. Defaults already point at /app.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/app
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/app

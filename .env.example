# Neon Postgres connection string.
# Create a project at https://console.neon.tech/, copy the pooled connection string here.
# Without this set, the app runs entirely on mock data.
DATABASE_URL=

# X (Twitter) v2 API Bearer token (Basic tier or higher).
# Without this set, /api/cron/ingest is a no-op even when DATABASE_URL is set.
X_API_BEARER=

# Required by /api/cron/* so the open internet can't trigger ingestion.
# Vercel's cron pings include `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: when set, narrative classification upgrades from keyword v0 to
# embedding-based clustering. Not yet wired (placeholder for next iteration).
OPENAI_API_KEY=

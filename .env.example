# Clerk auth. Get keys from https://dashboard.clerk.com/ -> API Keys.
# Required to gate /dashboard, /learn, /catechism behind real sign-in.
# When unset, the middleware is a no-op and /sign-in shows a "Clerk not
# configured" notice — the marketing site still renders.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

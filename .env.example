# Public site URL (used in metadata, sitemap, robots, OG tags)
NEXT_PUBLIC_SITE_URL=https://www.christianmusicgrp.com

# Password gate — required to access the site
SITE_PASSWORD=christianmusicgrp23!

# Resend API key (https://resend.com) — required for the contact form
RESEND_API_KEY=

# From address for outbound contact-form emails.
# Use "Christian Music Group <hello@christianmusicgrp.com>" after the domain
# is verified in Resend. Until then, "onboarding@resend.dev" works for testing.
CONTACT_FROM_EMAIL=Christian Music Group <onboarding@resend.dev>
